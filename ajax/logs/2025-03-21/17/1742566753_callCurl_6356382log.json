u0434\u043d\u0438\u043c \u043a\u0440\u043e\u043d\u0448\u0442\u0435\u0439\u043d\u043e\u043c) \u003Cbr\u003E\u2014 \u042d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0430\u044f \u043f\u0430\u043d\u0435\u043b\u044c \u043f\u0440\u0438\u0431\u043e\u0440\u043e\u0432 \u003Cbr\u003E\u2014 \u041f\u0435\u0440\u0435\u0434\u043d\u0435\u0435 \u0441\u0438\u0434\u0435\u043d\u044c\u0435 \u0441\u043e \u0441\u043f\u0438\u043d\u043a\u043e\u0439 \u003Cbr\u003E\u2014 \u0417\u0430\u0434\u043d\u0438\u0435 \u0431\u043e\u043a\u043e\u0432\u044b\u0435 \u0441\u0438\u0434\u0435\u043d\u044c\u044f (\u043f\u0440\u043e\u0434\u043e\u043b\u044c\u043d\u044b\u0435) \u003Cbr\u003E\u2014 \u0417\u0430\u0434\u043d\u0438\u0435 \u043d\u0438\u0437\u043a\u0438\u0435 \u043f\u0440\u043e\u0434\u043e\u043b\u044c\u043d\u044b\u0435 \u043f\u043e\u0440\u0443\u0447\u043d\u0438 \u003Cbr\u003E\u2014  \u0414\u0438\u0441\u043a \u00ab\u0411\u0435\u0434\u043b\u043e\u043a\u00bb (\u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442, 8 \u0448\u0442.) \u003Cbr\u003E\u2014 \u0413\u0443\u0441\u0435\u043d\u0438\u0446\u0430 \u0440\u0435\u0437\u0438\u043d\u043e\u0432\u0430\u044f \u0441 \u043c\u0435\u0442\u0430\u043b\u043b\u0438\u0447\u0435\u0441\u043a\u0438\u043c \u043a\u043e\u0440\u0434\u043e\u043c (\u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442, 2 \u0448\u0442.) \u003Cbr\u003E\u2014 \u0417\u0430\u043f\u0430\u0441\u043d\u043e\u0435 \u043a\u043e\u043b\u0435\u0441\u043e 25\u044512-9 (1 \u0448\u0442.) \u003Cbr\u003E\u2014 \u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043f\u0435\u0440\u0435\u0434\u043d\u0435\u0435 \u0441\u0432\u0435\u0442\u043e\u0434\u0438\u043e\u0434\u043d\u043e\u0435 \u043e\u0441\u0432\u0435\u0449\u0435\u043d\u0438\u0435 (850 \u043c\u043c) \u003Cbr\u003E\u2014 \u0417\u0430\u0434\u043d\u0438\u0435 \u043f\u043e\u0440\u0443\u0447\u043d\u0438 \u0441\u043e \u0441\u043f\u0438\u043d\u043a\u043e\u0439 \u003Cbr\u003E\u2014 \u041f\u0435\u0442\u043b\u0438 \u0434\u043b\u044f \u0444\u0438\u043a\u0441\u0430\u0446\u0438\u0438 \u0433\u0440\u0443\u0437\u0430 (\u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0442) \u003Cbr\u003E\u2014 \u0420\u043e\u0437\u0435\u0442\u043a\u0430 12V (2 \u0433\u043d\u0435\u0437\u0434\u0430) \u003Cbr\u003E\u2014 \u0422\u0440\u0430\u043d\u0435\u0446 \u0434\u043b\u044f \u043f\u043e\u0434\u0432\u0435\u0441\u043d\u043e\u0433\u043e \u043b\u043e\u0434\u043e\u0447\u043d\u043e\u0433\u043e \u043c\u043e\u0442\u043e\u0440\u0430 \u003Cbr\u003E\u2014 \u0417\u0430\u0449\u0438\u0442\u043d\u044b\u0439 \u0431\u0430\u043c\u043f\u0435\u0440 \u043f\u0435\u0440\u0435\u0434\u043d\u0438\u0439 \u003Cbr\u003E\u2014 \u041b\u0435\u0431\u0451\u0434\u043a\u0430 \u044d\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u003Cbr\u003E\u2014 \u041a\u0430\u0440\u043a\u0430\u0441 \u043f\u043e\u0434 \u0442\u0435\u043d\u0442 \u0441 \u043b\u043e\u0431\u043e\u0432\u044b\u043c \u0441\u0442\u0435\u043a\u043b\u043e\u043c \u0438 \u0436\u0451\u0441\u0442\u043a\u043e\u0439 \u043a\u0440\u044b\u0448\u0435\u0439 \u003Cbr\u003E\u2014 \u0422\u0435\u043d\u0442 \u0445\u043e\u0434\u043e\u0432\u043e\u0439 \u003Cbr\u003E\u2014 \u0411\u043e\u043a\u043e\u0432\u044b\u0435 \u0437\u0435\u0440\u043a\u0430\u043b\u0430 \u0437\u0430\u0434\u043d\u0435\u0433\u043e \u0432\u0438\u0434\u0430 \u003Cbr\u003E\u2014 \u0417\u0430\u0434\u043d\u0438\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u0442\u0435\u043b\u0438 (\u0431\u0440\u044b\u0437\u0433\u043e\u0432\u0438\u043a\u0438) \u003Cbr\u003E\u2014 \u0412\u0435\u0442\u043a\u043e\u0440\u0435\u0437 \u003Cbr\u003E\u2014 \u0424\u0430\u0440\u0430-\u0438\u0441\u043a\u0430\u0442\u0435\u043b\u044c \u003Cbr\u003E\u2014 \u041f\u0435\u0440\u0435\u0434\u043d\u0438\u0435 \u044d\u0440\u0433\u043e\u043d\u043e\u043c\u0438\u0447\u043d\u044b\u0435 \u0441\u0438\u0434\u0435\u043d\u044c\u044f \u003Cbr\u003E\u2014 \u0421\u0442\u0435\u043a\u043b\u043e\u043e\u0447\u0438\u0441\u0442\u0438\u0442\u0435\u043b\u044c \u043b\u043e\u0431\u043e\u0432\u043e\u0