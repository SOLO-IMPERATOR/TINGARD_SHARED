u0437\u0432\u0438\u0442\u0438\u044e.\n\u041f\u0440\u043e\u0435\u043a\u0442 \u00ab\u200e\u041c\u043e\u0439 \u0433\u0435\u043a\u0442\u0430\u0440\u00bb \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043e\u0432\u0430\u043d \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0435\u0439 \u00ab\u0411\u043e\u043b\u044c\u0448\u0430\u044f \u0437\u0435\u043c\u043b\u044f\u00bb \u0432 2016 \u0433\u043e\u0434\u0443 \u043f\u0440\u0438 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0435 \u0421\u043e\u044e\u0437\u0430 \u0441\u0430\u0434\u043e\u0432\u043e\u0434\u043e\u0432 \u0420\u043e\u0441\u0441\u0438\u0438. \u041c\u0438\u0441\u0441\u0438\u044f \u043f\u0440\u043e\u0435\u043a\u0442\u0430 \u2014 \u0434\u0430\u0442\u044c \u043a\u0430\u0436\u0434\u043e\u043c\u0443 \u0440\u043e\u0441\u0441\u0438\u044f\u043d\u0438\u043d\u0443 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043a\u0443\u043f\u0438\u0442\u044c \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u044c \u0441\u0432\u043e\u0439 \u0433\u0435\u043a\u0442\u0430\u0440 \u0437\u0435\u043c\u043b\u0438 \u043f\u043e \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0439 \u0446\u0435\u043d\u0435. \u0421\u0435\u0439\u0447\u0430\u0441 \u0432 \u043f\u0440\u043e\u0435\u043a\u0442\u0435 \u0443\u0436\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 6000 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u043e\u0432, \u0437\u0430\u043f\u0443\u0449\u0435\u043d\u043e \u0431\u043e\u043b\u0435\u0435 65 \u043f\u043e\u0441\u0435\u043b\u043a\u043e\u0432. \u0411\u0430\u043d\u043a \u0437\u0435\u043c\u043b\u0438 500000 \u0433\u0435\u043a\u0442\u0430\u0440. \u0417\u0435\u043c\u043b\u0438 \u043f\u043e\u0434 \u0418\u0416\u0421, \u0434\u0430\u0447\u043d\u043e\u0433\u043e \u0445\u043e\u0437\u044f\u0439\u0441\u0442\u0432\u0430, \u0444\u0435\u0440\u043c\u044b, \u0442\u0443\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0438\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u044b.\n\u0412 \u043f\u0440\u043e\u0448\u043b\u043e\u043c \u0433\u043e\u0434\u0443 \u043d\u0430 YouTube \u043a\u0430\u043d\u0430\u043b\u0435 \u043c\u044b \u0437\u0430\u043f\u0443\u0441\u0442\u0438\u043b\u0438 \u0431\u043b\u043e\u0433 \u00ab\u041e\u0442 \u0441\u043e\u0445\u0438 \u0434\u043e \u0441\u043e\u0445\u0438\u00bb. \u0422\u0430\u043c \u043c\u044b \u0440\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u043c \u043e \u0441\u0435\u043b\u044c\u0441\u043a\u043e\u043c \u0445\u043e\u0437\u044f\u0439\u0441\u0442\u0432\u0435, \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0435, \u0442\u0443\u0440\u0438\u0437\u043c\u0435. \u041e\u0431\u043e \u0432\u0441\u0435\u043c, \u0447\u0442\u043e \u0441\u0432\u044f\u0437\u0430\u043d\u043e \u0441 \u0436\u0438\u0437\u043d\u044c\u044e \u0437\u0430 \u0433\u043e\u0440\u043e\u0434\u043e\u043c.\n\u0421\u044a\u0435\u043c\u043a\u0438 \u043f\u0440\u043e\u0432\u043e\u0434\u044f\u0442\u0441\u044f \u0440\u0430\u0437 \u0432 \u043d\u0435\u0434\u0435\u043b\u044e, \u0432\u044b\u043f\u0443\u0441\u043a\u0438 \u0432\u044b\u0445\u043e\u0434\u044f\u0442 \u0440\u0430\u0437 \u0432 10 \u0434\u043d\u0435\u0439. \u0417\u0430 \u0433\u043e\u0434 \u043c\u044b \u0441\u0434\u0435\u043b\u0430\u043b\u0438 20 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0432\u044b\u043f\u0443\u0441\u043a\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0435\u043b\u0438 \u0431\u043e\u043b\u0435\u0435 100 000 \u0447\u0435\u043b\u043e\u0432\u0435\u043a. \u042d\u0442\u043e \u0446\u0435\u043b\u0435\u0432\u0430\u044f, \u0437\u0430\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f. \u041d\u0430 \u0434\u0430\u043d\u043d\u044b\u0439  \u043c\u043e\u043c\u0435\u043d\u0442 \u043c\u044b \u043d\u0430\u0440\u0430\u0449\u0438\u0432\u0430\u0435\u043c \u0440\u0435\u043a\u043b\u0430\u043c\u0443 \u0431\u043b\u043e\u0433\u0430 \u0432 YouTube \u0438 \u0432 2022-\u043c \u0433\u043e\u0434\u0443 \u043f\u043b\u0430\u043d\u0438\u0440\u0443\u0435\u043c \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0442\u044c \u043e\u0445\u0432\u0430\u0442\u044b \u0432 3-4 \u0440\u0430\u0437\u0430.\n\u041c\u044b \u0440\u0435\u0448\u0438\u043b\u0438 \u0432\u0432\u0435\u0441\u0442\u0438 \u0432 \u0431\u043b\u043e\u0433 \u0435\u0449\u0451 \u043e\u0434\u043d\u043e\u0433\u043e \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430 \u2014 \u0412\u0415\u0417\u0414\u0415\u0425\u041e\u0414 \u0432\u0435\u0434\u0443\u0449\u0435\u0433\u043e \u0441 \u0441\u0438\u043c\u0432\u043e\u043b\u0438\u043a\u043e\u0439 \u043f\u0440\u043e\u0435\u043a\u0442\u0430 \u00ab\u041c\u043e\u0439 \u0433\u0435\u043a\u0442\u0430\u0440\u00bb. \u041d\u0430\u0434\u0435\u0436\u043d\u044b\u0439, \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u043c\u044b\u0439, \u0434\u043b\u044f \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f \u043f\u043e \u043b\u0435\u0441\u043d\u044b\u043c \u0438 \u0441\u0435\u043b\u044c\u0441\u043a\u0438\u043c \u0434\u043e\u0440\u043e\u0433\u0430\u043c. \u041c\u044b \u0445\u043e\u0442\u0438\u043c \u0434\u043e\u0435\u0437\u0436\u0430\u0442\u044c, \u0434\u0430\u0436\u0435 \u043f\u043e \u0431\u0435\u0437\u0434\u043e\u0440\u043e\u0436\u044c\u044e, \u0434\u043e \u043d\u0430\u0448\u0438\u0445 \u0433\u0435\u0440\u043e\u0435\u0432, \u0434\u0435\u043b\u0430\u0442\u044c \u043f\u043e\u0434\u0432\u043e\u0434\u043a\u0438 \u0438 \u0438\u043d\u0442\u0435\u0440\u0432\u044c\u044e \u043d\u0430 \u0444\u043e\u043d\u0435 \u0412\u0415\u0417\u0414\u0415\u0425\u041e\u0414\u0410, \u043e\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043b\u044f\u0442\u044c \u043f\u043e\u043a\u0430\u0437\u044b \u043d\u0430\u0448\u0438\u0445 \u043f\u043e\u0441\u0435\u043b\u043a\u043e\u0432. \u041c\u044b \u0441\u0447\u0438\u0442\u0430\u0435\u043c, \u0447\u0442\u043e \u0412\u0415\u0417\u0414\u0415\u0425\u041e\u0414 \u0445\u043e\u0440\u043e\u0448\u043e \u0432\u043f\u0438\u0441\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0432 \u043d\u0430\u0448 \u0444\u043e\u0440\u043c\u0430\u0442. \u0412\u0435\u0434\u044c \u043c\u044b \u0438 \u043d\u0430\u0448\u0438 \u043a\u043b\u0438\u0435\u043d\u0442\u044b \u0438\u043d\u043d\u043e\u0432\u0430\u0442\u043e\u0440\u044b, \u0433\u043e\u0442\u043e\u0432\u044b\u0435 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438 \u043d\u0430\u0448\u0435\u0439 \u0420\u043e\u0434\u0438\u043d\u044b. \n\u0411\u0440\u0435\u043d\u0434 \u00ab\u200e\u041c\u043e\u0439 \u0433\u0435\u043a\u0442\u0430\u0440\u00bb \u0437\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0435 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043b\u0435\u0442 \u0441\u0442\u0430\u043b \u0443\u0437\u043d\u0430\u0432\u0430\u0435\u043c, \u043d\u0430\u0440\u0443\u0436\u043d\u0430\u044f \u0440\u0435\u043a\u043b\u0430\u043c\u0430 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0432\u0438\u0441\u0438\u0442 \u043f\u043e \u0432\u0441\u0435\u0439 \u041c\u043e\u0441\u043a\u0432\u0435, \u041c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u0439 \u0438 \u0422\u0432\u0435\u0440\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438, \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u0447\u0430\u0435\u0442 \u0441\u043e \u0421\u041c\u0418, \u0440\u0430\u0434\u0438\u043e \u0438 \u0422\u0412. \u041e \u043d\u0430\u0441 \u043c\u043e\u0436\u043d\u043e \u043f\u0440\u043e\u0447\u0438\u0442\u0430\u0442\u044c \u0432 \u0420\u0411\u041a.\u041d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c, \u043f\u043e\u0441\u043b\u0443\u0448\u0430\u0442\u044c \u043d\u0430 \u0440\u0430\u0434\u0438\u043e \u041a\u043e\u043c\u0441\u043e\u043c\u043e\u043b\u044c\u0441\u043a\u0430\u044f \u043f\u0440\u0430\u0432\u0434\u0430, Megapolis \u0438 \u043d\u0430 \u0434\u0440\u0443\u0433\u0438\u0445 \u0444\u0435\u0434\u0435\u0440\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u043b\u043e\u0449\u0430\u0434\u043a\u0430\u0445.\n\u041c\u044b \u0433\u043e\u0442\u043e\u0432\u044b \u0440\u0430\u0437\u043c\u0435\u0449\u0430\u0442\u044c \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u043e \u043f\u0430\u0440\u0442\u043d\u0435\u0440\u0430\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u0430 \u043d\u0430 \u0441\u0430\u0439\u0442\u0435, \u0432 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0441\u0435\u0442\u044f\u0445, \u0432 \u0440\u0430\u0441\u0441\u044b\u043b\u043a\u0430\u0445, \u0447\u0442\u043e \u043f\u0440\u0438\u043d\u0435\u0441\u0435\u0442 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043e\u0445\u0432\u0430\u0442 \u0432 500 000 \u0447\u0435\u043b\u043e\u0432\u0435\u043a \u0435\u0436\u0435\u043c\u0435\u0441\u044f\u0447\u043d\u043e.\n\u0415\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0439 \u043e\u0445\u0432\u0430\u0442 \u0440\u0430\u0434\u0438\u043e\u0441\u0442\u0430\u043d\u0446\u0438\u0439, \u043d\u0430 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u043c\u044b \u0440\u0430\u0437\u043c\u0435\u0449\u0430\u0435\u043c \u0440\u0435\u043a\u043b\u0430\u043c\u0443, \u043e\u043a\u043e\u043b\u043e 4 \u043c\u043b\u043d \u0447\u0435\u043b\u043e\u0432\u0435\u043a. \u041d\u0430\u0440\u0443\u0436\u043d\u0430\u044f \u0440\u0435\u043a\u043b\u0430\u043c\u0430 \u043f\u043e \u041c\u043e\u0441\u043a\u0432\u0435 \u0438 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 - \u0431\u043e\u043b\u0435\u0435 300 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0439 \u0441 \u043e\u0445\u0432\u0430\u0442\u043e\u043c \u0431\u043e\u043b\u0435\u0435 3 \u043c\u043b\u043d \u0447\u0435\u043b\u043e\u0432\u0435\u043a. \u0410 \u043d\u0430\u0448 \u043a\u0430\u043d\u0430\u043b \u043d\u0430 YouTube \u043f\u043e\u043b\u0443\u0447\u0438\u043b \u0431\u043e\u043b\u0435\u0435 3,5 \u043c\u043b\u043d \u043f